  "scripts": {
    "check": "node --check extension.js",
    "test": "node --test ./test/*.test.js",
    "prepackage": "npm run check && npm test",
    "package": "npx @vscode/vsce package --allow-missing-repository --out mdtomd-vscode.vsix"
  }
}

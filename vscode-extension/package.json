{
  "name": "mdtomd-vscode",
  "displayName": "mdtomd",
  "description": "在 VS Code 里右键翻译 Markdown，支持先估算价格再选择模型",
  "version": "0.1.4",
  "publisher": "ailuntz",
  "icon": "media/icon.png",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/ailuntx/mdtomd.git",
    "directory": "vscode-extension"
  },
  "homepage": "https://github.com/ailuntx/mdtomd/tree/main/vscode-extension",
  "keywords": [
    "markdown",
    "mdx",
    "translation",
    "llm"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mdtomd.translateResource",
    "onCommand:mdtomd.translateCurrentFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mdtomd.translateResource",
        "title": "mdtomd: 翻译 Markdown"
      },
      {
        "command": "mdtomd.translateCurrentFile",
        "title": "mdtomd: 翻译当前 Markdown"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mdtomd.translateResource",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@9"
        },
        {
          "command": "mdtomd.translateResource",
          "when": "explorerResourceIsFolder",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": [
      {
        "title": "mdtomd 通用",
        "properties": {
          "mdtomd.cliPath": {
            "type": "string",
            "default": "",
            "description": "mdtomd CLI 可执行文件路径。留空时会依次尝试 mdtomd、python3 -m mdtomd、python -m mdtomd。"
          },
          "mdtomd.pythonPath": {
            "type": "string",
            "default": "python3",
            "description": "回退到 python -m mdtomd 时使用的 Python 可执行文件。"
          },
          "mdtomd.targetLanguage": {
            "type": "string",
            "default": "Chinese",
            "enum": [
              "Spanish",
              "French",
              "German",
              "Italian",
              "Portuguese",
              "Dutch",
              "Russian",
              "Chinese",
              "Japanese",
              "Korean",
              "Arabic",
              "Hindi",
              "Turkish",
              "Polish",
              "Swedish",
              "Norwegian",
              "Danish",
              "Finnish",
              "Greek",
              "Hebrew",
              "Thai",
              "Vietnamese",
              "Indonesian",
              "Malay",
              "Ukrainian",
              "Czech",
              "Hungarian",
              "Romanian",
              "Bulgarian",
              "Croatian",
              "Serbian",
              "Slovak",
              "Slovenian",
              "Estonian",
              "Latvian",
              "Lithuanian",
              "Catalan",
              "Basque",
              "Welsh",
              "Irish"
            ],
            "description": "目标语言。优先级高于 config.yaml 的 defaults.language。"
          },
          "mdtomd.languageSuffixes": {
            "type": "object",
            "default": {
              "Spanish": "es",
              "French": "fr",
              "German": "de",
              "Italian": "it",
              "Portuguese": "pt",
              "Dutch": "nl",
              "Russian": "ru",
              "Chinese": "zh",
              "Japanese": "ja",
              "Korean": "ko",
              "Arabic": "ar",
              "Hindi": "hi",
              "Turkish": "tr",
              "Polish": "pl",
              "Swedish": "sv",
              "Norwegian": "no",
              "Danish": "da",
              "Finnish": "fi",
              "Greek": "el",
              "Hebrew": "he",
              "Thai": "th",
              "Vietnamese": "vi",
              "Indonesian": "id",
              "Malay": "ms",
              "Ukrainian": "uk",
              "Czech": "cs",
              "Hungarian": "hu",
              "Romanian": "ro",
              "Bulgarian": "bg",
              "Croatian": "hr",
              "Serbian": "sr",
              "Slovak": "sk",
              "Slovenian": "sl",
              "Estonian": "et",
              "Latvian": "lv",
              "Lithuanian": "lt",
              "Catalan": "ca",
              "Basque": "eu",
              "Welsh": "cy",
              "Irish": "ga"
            },
            "additionalProperties": {
              "type": "string"
            },
            "description": "语言到输出文件后缀的映射。优先级高于 config.yaml 的 defaults.suffix。"
          },
          "mdtomd.showOutputChannelOnSuccess": {
            "type": "boolean",
            "default": false,
            "description": "命令成功后也自动打开 mdtomd 输出面板。"
          },
          "mdtomd.timeoutSec": {
            "type": "number",
            "default": 120,
            "minimum": 1,
            "description": "LLM 请求超时秒数。会作为 --timeout-sec 传给 CLI，优先级高于 config.yaml 的 llm.timeout_sec。"
          }
        }
      },
      {
        "title": "mdtomd DeepSeek",
        "properties": {
          "mdtomd.deepseek.model": {
            "type": "string",
            "default": "",
            "description": "DeepSeek 的 model，例如 deepseek-chat"
          },
          "mdtomd.deepseek.baseUrl": {
            "type": "string",
            "default": "https://api.deepseek.com/v1",
            "description": "DeepSeek 的 base_url"
          },
          "mdtomd.deepseek.apiKey": {
            "type": "string",
            "default": "",
            "description": "DeepSeek 的 api_key"
          },
          "mdtomd.deepseek.apiKeyEnv": {
            "type": "string",
            "default": "DEEPSEEK_API_KEY",
            "description": "DeepSeek 的 api_key_env"
          },
          "mdtomd.deepseek.apiMode": {
            "type": "string",
            "default": "chat_completions",
            "description": "DeepSeek 的 api_mode"
          },
          "mdtomd.deepseek.maxTokens": {
            "type": "number",
            "default": 8192,
            "description": "DeepSeek 的 max_tokens"
          }
        }
      },
      {

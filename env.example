# mdtomd LLM configuration
#
# 通用选择
# MD_TRANSLATE_PROVIDER=auto
# MD_TRANSLATE_MODEL=
# MD_TRANSLATE_BASE_URL=
# MD_TRANSLATE_API_KEY=
# MD_TRANSLATE_API_KEY_ENV=
# MD_TRANSLATE_CODEX_HOME=
# MD_TRANSLATE_CODEX_AUTH_FILE=
# MD_TRANSLATE_API_MODE=auto
#
# 推荐: 在 config.yaml 的 providers.<name>.api_key 里直接写 key
# 临时测试: 再用下面这些环境变量
#
# 常见 provider API key
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_CODEX_ACCESS_TOKEN=
# CODEX_ACCESS_TOKEN=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# NOUS_API_KEY=
# GLM_API_KEY=
# NOVITA_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_CN_API_KEY=
# KIMI_API_KEY=
# DASHSCOPE_API_KEY=
# HF_TOKEN=
# AI_GATEWAY_API_KEY=
# OPENCODE_ZEN_API_KEY=
# OPENCODE_GO_API_KEY=
# KILOCODE_API_KEY=
# COPILOT_GITHUB_TOKEN=
#
# Codex CLI 登录态
# CODEX_HOME=~/.codex
#
# 自建 OpenAI 兼容接口
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=your-key
